{
  "manifest_version": 2,
  "name": "Vantyr URL Provider",
  "version": "0.1.0",
  "description": "Reports active tab URL metadata to the local Vantyr agent.",
  "permissions": ["tabs", "nativeMessaging"],
  "background": {
    "scripts": ["background.js"]
  },
  "incognito": "not_allowed",
  "applications": {
    "gecko": {
      "id": "url-provider@vantyr.local"
    }
  }
}
